erDiagram
    DIM_DATE ||--o{ FACT_SALES : "date_key"
    DIM_PRODUCT ||--o{ FACT_SALES : "product_key"
    DIM_STORE ||--o{ FACT_SALES : "store_key"
    DIM_CUSTOMER ||--o{ FACT_SALES : "customer_key"
    DIM_CHANNEL ||--o{ FACT_SALES : "channel_key"

    FACT_SALES {
        string order_number "degenerate dimension"
        int sale_line_id "line identifier"
        date date_key "FK"
        int customer_key "FK"
        int product_key "FK"
        int store_key "FK"
        int channel_key "FK"
        int quantity "additive"
        decimal unit_price
        decimal discount_pct "non-additive"
        decimal net_price
        decimal line_total "additive"
        decimal gross_amount "additive"
    }

    DIM_DATE {
        date date_key "PK"
        int year
        int quarter
        int month
        string month_name
        int week_iso
        boolean is_weekend
    }

    DIM_PRODUCT {
        int product_key "PK"
        string product_id
        string product_name
        string category
        string subcategory
        string brand
        decimal unit_cost
        decimal unit_price
    }

    DIM_STORE {
        int store_key "PK"
        string store_id
        string store_name
        string city
        string region
        string province
        string store_type
    }

    DIM_CUSTOMER {
        int customer_key "PK"
        string customer_id
        string full_name
        string city
        string province
        string loyalty_segment
        date join_date
        boolean is_current
    }

    DIM_CHANNEL {
        int channel_key "PK"
        string channel_id
        string channel_name
        string channel_type
    }
